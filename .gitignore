# ═══════════════════════════════════════════════════════════════
# ARTI Universal Platform — .gitignore
# ═══════════════════════════════════════════════════════════════

# 🔐 API KEY və həssas məlumatlar (MÜTLƏQİDİR!)
.env
.env.local
.env.*.local
**/.env
**/shared/.env
*api_key*
*secret*
*password*
*.pem
*.key

# 📊 Məlumat bazası backup-ları (həcmə görə)
*.sql.backup
*.dump
*.backup
pg_dump_*
db_backup_*

# 📝 R fayılları
.Rhistory
.RData
.Rproj.user/
.Ruserdata
*.Rproj

# 📦 Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.yarn/

# 🍎 Mac
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# 🐍 Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/

# 🗄️ IDE/Editor
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# 📋 Log-lar
*.log
logs/
*.pid

# 💾 Temp fayılları
*.tmp
*.bak
*.backup_*
*.old
*.old_*
.cache/

# 🌐 Shiny deployment
rsconnect/
shiny-server.conf

# 📁 Başqaları
.Trashes
.fuse_hidden*
.directory

# 🤖 AI arxiv — istəyə görə (böyük ola bilər)
# docs/Sorğu_nəticələri/*.html
