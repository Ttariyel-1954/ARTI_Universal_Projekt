# ═══ CLAUDE AI — Token və qiymət qaytaran ═══
ask_claude_enhanced <- function(sys_prompt, user_prompt, max_tokens = 3500) {
  if (CLAUDE_API_KEY == "") {
    return(list(
      text = "⚠️ API açarı yoxdur",
      input_tokens = 0, output_tokens = 0,
      duration_sec = 0, cost_usd = 0
    ))
  }
  
  start_time <- Sys.time()
  
  tryCatch({
    resp <- request("https://api.anthropic.com/v1/messages") |>
      req_headers(
        "x-api-key" = CLAUDE_API_KEY,
        "anthropic-version" = "2023-06-01",
        "content-type" = "application/json"
      ) |>
      req_body_json(list(
        model = CLAUDE_MODEL,
        max_tokens = max_tokens,
        system = sys_prompt,
        messages = list(list(role = "user", content = user_prompt))
      )) |>
      req_timeout(120) |>
      req_perform()
    
    body <- resp_body_json(resp)
    duration <- as.numeric(difftime(Sys.time(), start_time, units = "secs"))
    
    input_tok  <- body$usage$input_tokens
    output_tok <- body$usage$output_tokens
    
    cost_usd <- (input_tok / 1e6) * PRICE_INPUT_PER_MTOK +
                (output_tok / 1e6) * PRICE_OUTPUT_PER_MTOK
    
    list(
      text = body$content[[1]]$text,
      input_tokens = input_tok,
      output_tokens = output_tok,
      total_tokens = input_tok + output_tok,
      duration_sec = round(duration, 1),
      cost_usd = round(cost_usd, 4),
      cost_azn = round(cost_usd * USD_TO_AZN, 3),
      model = CLAUDE_MODEL,
      finished_at = format(Sys.time(), "%H:%M:%S")
    )
  }, error = function(e) {
    list(
      text = paste("❌ Xəta:", e$message),
      input_tokens = 0, output_tokens = 0,
      duration_sec = as.numeric(difftime(Sys.time(), start_time, units = "secs")),
      cost_usd = 0, cost_azn = 0, model = CLAUDE_MODEL,
      finished_at = format(Sys.time(), "%H:%M:%S")
    )
  })
}

