# ═══════════════════════════════════════════════════════════════
# SERVER
# ═══════════════════════════════════════════════════════════════
server <- function(input, output, session) {
  
  # ═══ REACTIVE DATA (cache) ═══
  kpi_data       <- reactive({ safe_query("SELECT * FROM reporting.mv_kpi") })
  regions_data   <- reactive({ safe_query("SELECT * FROM reporting.mv_regional_overview") })
  projects_data  <- reactive({ safe_query("SELECT * FROM reporting.mv_project_status") })
  budget_data    <- reactive({ safe_query("SELECT * FROM reporting.mv_budget_tracking") })
  contractors_data <- reactive({ safe_query("SELECT * FROM reporting.mv_contractor_performance WHERE total_projects > 0 ORDER BY total_projects DESC") })
  materials_data <- reactive({ safe_query("SELECT * FROM reporting.mv_material_flow ORDER BY total_out_value DESC LIMIT 100") })
  warehouses_data <- reactive({ safe_query("SELECT * FROM reporting.v_warehouse_summary") })
  inspections_data <- reactive({ safe_query("SELECT * FROM reporting.mv_inspection_summary ORDER BY inspection_date DESC LIMIT 200") })
  complaints_data <- reactive({ safe_query("SELECT * FROM reporting.mv_complaint_analysis ORDER BY complaint_date DESC LIMIT 200") })
  deadlines_data <- reactive({ safe_query("SELECT * FROM reporting.mv_deadline_monitoring WHERE status IN ('in_progress','approved','planned') ORDER BY planned_end") })
  yearly_data    <- reactive({ safe_query("SELECT * FROM reporting.mv_yearly_summary") })
  schools_data   <- reactive({ safe_query("SELECT * FROM reporting.v_school_repair_history WHERE total_projects > 0 ORDER BY total_spent_k DESC") })

  # ═══ KPI ═══
  output$kpi_regions <- renderbs4ValueBox({
    bs4ValueBox(value = kpi_data()$total_regions, subtitle = "Rayon",
                icon = icon("map-location-dot"), color = "primary") })
  output$kpi_schools <- renderbs4ValueBox({
    bs4ValueBox(value = kpi_data()$total_schools, subtitle = "Məktəb",
                icon = icon("school"), color = "info") })
  output$kpi_projects <- renderbs4ValueBox({
    bs4ValueBox(value = kpi_data()$total_projects, subtitle = "Layihə",
                icon = icon("diagram-project"), color = "success") })
  output$kpi_active <- renderbs4ValueBox({
    bs4ValueBox(value = kpi_data()$active_projects, subtitle = "Aktiv layihə",
                icon = icon("rocket"), color = "warning") })
  output$kpi_planned <- renderbs4ValueBox({
    bs4ValueBox(value = paste0(kpi_data()$total_planned_mln, " mln"), subtitle = "Planlaşdırılmış (AZN)",
                icon = icon("sack-dollar"), color = "success") })
  output$kpi_spent <- renderbs4ValueBox({
    bs4ValueBox(value = paste0(kpi_data()$total_spent_mln, " mln"), subtitle = "Xərclənmiş (AZN)",
                icon = icon("money-bill-trend-up"), color = "warning") })
  output$kpi_quality <- renderbs4ValueBox({
    bs4ValueBox(value = paste0(kpi_data()$avg_quality, "/10"), subtitle = "Orta keyfiyyət",
                icon = icon("star"), color = "info") })
  output$kpi_complaints <- renderbs4ValueBox({
    bs4ValueBox(value = kpi_data()$pending_complaints, subtitle = "Həlli gözləyən",
                icon = icon("bullhorn"), color = "danger") })

  # ═══ ÜMUMİ BAXIŞ QRAFİKLƏRİ ═══
  output$plot_status <- renderPlotly({
    d <- projects_data() |> count(status) |> arrange(desc(n))
    plot_ly(d, labels = ~status, values = ~n, type = "pie", hole = 0.4,
            marker = list(colors = c("#059669","#0369a1","#f59e0b","#7c3aed","#dc2626"))) |>
      layout(margin = list(t=10, b=10))
  })
  output$plot_types <- renderPlotly({
    d <- projects_data() |> count(project_type) |> arrange(desc(n))
    plot_ly(d, x = ~project_type, y = ~n, type = "bar",
            marker = list(color = c("#0369a1","#7c3aed","#059669","#f59e0b","#dc2626"))) |>
      layout(xaxis = list(title=""), yaxis = list(title="Layihə sayı"))
  })

  # ═══ XƏRİTƏ ═══
  output$map_regions <- renderLeaflet({
    d <- regions_data() |> filter(!is.na(lat), !is.na(lng))
    pal <- colorNumeric(c("#dbeafe","#3b82f6","#1e3a8a"), domain = d$project_count)
    leaflet(d) |>
      addProviderTiles("CartoDB.Positron") |>
      setView(lng = 47.5, lat = 40.3, zoom = 7) |>
      addCircleMarkers(
        lng = ~lng, lat = ~lat,
        radius = ~sqrt(project_count + 1) * 3 + 5,
        color = ~pal(project_count),
        fillOpacity = 0.7, stroke = TRUE, weight = 2,
        popup = ~paste0("<b>", region_name, "</b><br>",
                        "🏫 Məktəb: ", school_count, "<br>",
                        "🏗️ Layihə: ", project_count, "<br>",
                        "▶️ Aktiv: ", active_projects, "<br>",
                        "✅ Tamam: ", completed_projects, "<br>",
                        "💰 Büdcə: ", planned_mln, " mln AZN")
      ) |>
      addLegend(pal = pal, values = ~project_count, 
                title = "Layihə sayı", position = "bottomright")
  })

  # ═══ LAYİHƏLƏR ═══
  observe({
    d <- regions_data()
    updateSelectInput(session, "flt_region_p",
      choices = c("Hamısı"="all", setNames(as.character(d$region_id), d$region_name)))
  })
  output$tbl_projects <- renderDT({
    d <- projects_data()
    if (input$flt_status != "all") d <- d[d$status == input$flt_status, ]
    d <- d[d$planned_budget/1000 >= input$flt_budget, ]
    d <- d[d$priority >= input$flt_priority[1] & d$priority <= input$flt_priority[2], ]
    datatable(d[, c("project_code","project_name","region_name","project_type",
                    "status","priority","progress_percent","planned_budget","actual_cost")],
      options = list(pageLength = 15, scrollX = TRUE), rownames = FALSE,
      colnames = c("Kod","Ad","Rayon","Növ","Status","Prioritet","İcra %","Plan","Fakt")) |>
      formatStyle("status",
        backgroundColor = styleEqual(
          c("completed","in_progress","planned","approved","on_hold","cancelled"),
          c("#d1fae5","#dbeafe","#fef3c7","#e0e7ff","#fee2e2","#f1f5f9"))) |>
      formatCurrency(c("planned_budget","actual_cost"), currency = "", mark = ",")
  })

  # ═══ BÜDCƏ ═══
  output$plot_budget_yearly <- renderPlotly({
    d <- budget_data() |> group_by(fiscal_year) |> 
      summarise(allocated = sum(allocated_amount)/1e6, spent = sum(spent_amount)/1e6)
    plot_ly(d) |>
      add_trace(x = ~fiscal_year, y = ~allocated, type = "bar", name = "Planlaşdırılmış",
                marker = list(color = "#0369a1")) |>
      add_trace(x = ~fiscal_year, y = ~spent, type = "bar", name = "Xərclənmiş",
                marker = list(color = "#7c3aed")) |>
      layout(barmode = "group", xaxis = list(title = ""), yaxis = list(title = "mln AZN"))
  })
  output$tbl_budget <- renderDT({
    datatable(budget_data(), options = list(pageLength = 15, scrollX = TRUE), rownames = FALSE) |>
      formatStyle("execution_level",
        backgroundColor = styleEqual(
          c("Boş","Aşağı icra","Orta icra","Yaxşı icra","Tam icra"),
          c("#f1f5f9","#fee2e2","#fef3c7","#dbeafe","#d1fae5")))
  })

  # ═══ MƏKTƏBLƏR ═══
  output$tbl_schools <- renderDT({
    datatable(schools_data(), options = list(pageLength = 15, scrollX = TRUE), rownames = FALSE) |>
      formatStyle("condition",
        backgroundColor = styleEqual(
          c("excellent","good","satisfactory","poor","critical"),
          c("#d1fae5","#dbeafe","#fef3c7","#fed7aa","#fee2e2")))
  })

  # ═══ MATERİALLAR ═══
  output$tbl_materials <- renderDT({
    datatable(materials_data(), options = list(pageLength = 15, scrollX = TRUE), rownames = FALSE) })
  output$tbl_warehouses <- renderDT({
    datatable(warehouses_data(), options = list(pageLength = 15, scrollX = TRUE), rownames = FALSE) })

  # ═══ PODRATÇILAR ═══
  output$tbl_contractors <- renderDT({
    datatable(contractors_data(), options = list(pageLength = 15, scrollX = TRUE), rownames = FALSE) |>
      formatStyle("rating",
        backgroundColor = styleInterval(c(5, 7, 8.5), c("#fee2e2","#fef3c7","#dbeafe","#d1fae5")))
  })
  output$plot_contractors <- renderPlotly({
    plot_ly(contractors_data(), x = ~rating, type = "histogram", 
            marker = list(color = "#7c3aed", line = list(color = "white", width = 2))) |>
      layout(xaxis = list(title = "Reytinq"), yaxis = list(title = "Podratçı sayı"))
  })

  # ═══ YOXLAMALAR ═══
  output$ins_total <- renderbs4ValueBox({
    n <- nrow(safe_query("SELECT 1 FROM construction.inspections"))
    bs4ValueBox(value = n, subtitle = "Yoxlama", icon = icon("clipboard-check"), color = "primary") })
  output$ins_quality <- renderbs4ValueBox({
    bs4ValueBox(value = paste0(kpi_data()$avg_quality, "/10"), subtitle = "Orta keyfiyyət",
                icon = icon("star"), color = "success") })
  output$ins_issues <- renderbs4ValueBox({
    n <- sum(inspections_data()$unresolved, na.rm = TRUE)
    bs4ValueBox(value = n, subtitle = "Həll olunmamış nöqsan",
                icon = icon("triangle-exclamation"), color = "warning") })
  output$plot_inspections <- renderPlotly({
    d <- inspections_data() |> count(inspection_type, quality_label) |> arrange(desc(n))
    plot_ly(d, x = ~inspection_type, y = ~n, color = ~quality_label, type = "bar",
            colors = c("#10b981","#3b82f6","#f59e0b","#ef4444")) |>
      layout(barmode = "stack", xaxis = list(title=""), yaxis = list(title="Sayı"))
  })
  output$tbl_inspections <- renderDT({
    datatable(inspections_data(), options = list(pageLength = 15, scrollX = TRUE), rownames = FALSE) })

  # ═══ ŞİKAYƏTLƏR ═══
  output$cmp_total <- renderbs4ValueBox({
    bs4ValueBox(value = nrow(complaints_data()), subtitle = "Cəmi",
                icon = icon("bullhorn"), color = "primary") })
  output$cmp_resolved <- renderbs4ValueBox({
    n <- sum(complaints_data()$status %in% c("resolved","closed"), na.rm = TRUE)
    bs4ValueBox(value = n, subtitle = "Həll olunmuş", icon = icon("check"), color = "success") })
  output$cmp_pending <- renderbs4ValueBox({
    n <- sum(complaints_data()$status %in% c("new","investigating"), na.rm = TRUE)
    bs4ValueBox(value = n, subtitle = "Gözləyir", icon = icon("hourglass-half"), color = "warning") })
  output$cmp_avg_days <- renderbs4ValueBox({
    avg <- round(mean(complaints_data()$resolution_days, na.rm = TRUE), 1)
    bs4ValueBox(value = paste0(avg, " gün"), subtitle = "Orta həll vaxtı",
                icon = icon("clock"), color = "info") })
  output$plot_comp_cat <- renderPlotly({
    d <- complaints_data() |> count(category) |> arrange(desc(n))
    plot_ly(d, labels = ~category, values = ~n, type = "pie", hole = 0.3)
  })
  output$plot_comp_chan <- renderPlotly({
    d <- complaints_data() |> count(channel) |> arrange(desc(n))
    plot_ly(d, x = ~channel, y = ~n, type = "bar", marker = list(color = "#7c3aed"))
  })
  output$tbl_complaints <- renderDT({
    datatable(complaints_data(), options = list(pageLength = 15, scrollX = TRUE), rownames = FALSE) })

  # ═══ DEADLINE ═══
  output$tbl_deadlines <- renderDT({
    datatable(deadlines_data(), options = list(pageLength = 15, scrollX = TRUE), rownames = FALSE)
  })

  # ═══ TRENDLƏR ═══
  output$plot_yearly <- renderPlotly({
