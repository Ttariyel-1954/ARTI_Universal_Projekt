    # Nəticəni göstər
    ai_state$response <- result
  }

  # ═══ run_ai — ARXIV variantı (strateji sorğular üçün) ═══
  run_ai_with_archive <- function(topic, cache_key, section_label, 
                                    questions_list, sys, usr) {
    # Cache-dən
    if (!is.null(ai_cache[[cache_key]])) {
      ai_state$topic <- paste(topic, "💾")
      ai_state$response <- ai_cache[[cache_key]]
      return()
    }
    
    # Progress overlay
    w <- Waiter$new(
      id = "ai_output",
      html = tagList(
        tags$div(class = "ai-thinking-box", style = "max-width:600px; margin:0 auto;",
          tags$div(class = "ai-pulse", "🧠"),
          tags$h3(style="margin:0; font-weight:700;", "Claude AI düşünür..."),
          tags$p(style="opacity:0.9; margin:10px 0 0 0; font-size:16px;", topic),
          tags$div(class = "ai-progress-bar", tags$div(class = "ai-progress-fill")),
          tags$div(style="margin-top:20px; max-width:500px; margin-left:auto; margin-right:auto; text-align:left;",
            tags$div(class="ai-step s1", "⏳ Sualları oxuyur..."),
            tags$div(class="ai-step s2", "🔍 Məlumat bazasını təhlil edir..."),
            tags$div(class="ai-step s3", "💭 Strateji təhlil formalaşdırır..."),
            tags$div(class="ai-step s4", "✍️ Hesabatı hazırlayır...")
          ),
          tags$div(style="margin-top:20px; opacity:0.85; font-size:13px;",
            "Model: ", CLAUDE_MODEL, " · 20-60 saniyə gözləyin")
        )
      ),
      color = "rgba(255,255,255,0.95)"
    )
    w$show()
    on.exit(w$hide())
    
    ai_state$topic <- topic
    result <- ask_claude_enhanced(sys, usr, 4000)
    
    # ARXIVƏ YAZ
    archive_result <- save_to_archive(
      topic = topic,
      section_name = section_label,
      questions_list = questions_list,
      response_text = result$text,
      metadata = result
    )
    
    if (isTRUE(archive_result$success)) {
      result$archive_file <- archive_result$filename
      result$archive_path <- archive_result$filepath
    }
    
    ai_cache[[cache_key]] <- result
    ai_state$response <- result
  }


