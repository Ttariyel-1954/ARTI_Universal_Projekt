      "to_char(MAX(attempted_at) AT TIME ZONE 'Asia/Baku', 'MM-DD HH24:MI') AS son_cehd ",
      "FROM audit.login_history ",
      "WHERE status = 'failed' AND attempted_at > NOW() - INTERVAL '30 days' ",
      "GROUP BY username ORDER BY COUNT(*) DESC LIMIT 20"
    )
    d <- safe_query(sql)
    if (nrow(d) == 0) {
      return(datatable(data.frame(Mesaj = "Ugursuz cehd yoxdur")))
    }
    datatable(d, options = list(pageLength = 8), rownames = FALSE,
              colnames = c("User","Cehd sayi","Son IP","Son cehd"))
  })
  
  cat("[INFO] Construction app başladı:", session$token, "\n")
  session$onSessionEnded(function() cat("[INFO] Sessiya bağlandı\n"))
}

shinyApp(ui, server)
